# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Domain that Caddy will serve and issue a TLS certificate for.
# Use "localhost" for local development (Caddy will mint a local cert).
VELOX_DOMAIN=your.domain.com

# Log level for the velox server: TRACE | DEBUG | INFO | WARN | ERROR | OFF
RUST_LOG=INFO

# ── QUIC transport ─────────────────────────────────────────────────────────────────
# QUIC UDP port. The velox binary must be built with --features quic.
# QUIC is exposed directly (Caddy cannot proxy UDP). Clients connect with:
#   velox client -L socks5://127.0.0.1:1080 quic://your.domain.com:8443
# Set QUIC_BIND to empty string to disable QUIC entirely.
QUIC_PORT=8443
QUIC_BIND=[::]:8443

# Extra CLI flags to pass to `velox server …`.
# Example: --restrict-to google.com:443 --restrict-to localhost:22
# Leave blank for no extra flags.
VELOX_EXTRA_ARGS=
